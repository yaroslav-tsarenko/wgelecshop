# ============================================================
# Database — Prisma Postgres
# ============================================================

# Prisma Postgres protocol URL (used by Prisma CLI)
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# Direct PostgreSQL connection (used by app runtime and seed)
DIRECT_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# ============================================================
# Auth
# ============================================================
JWT_SECRET="change-this-to-a-random-secret-in-production"

# ============================================================
# App Config
# ============================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================================
# Cloudflare R2 — Image CDN Storage
# ============================================================
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# ============================================================
# Social Media
# ============================================================
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/your-handle/"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/company/your-company/"

# ============================================================
# Resend — transactional emails (welcome, order confirmation,
# invoice, shipping, password reset, contact form)
# ============================================================
RESEND_API_KEY="re_xxxxx"
# Sender (must be a verified domain in Resend). Display name is optional.
RESEND_FROM_EMAIL="WGELECSHOP <noreply@wgelecshop.com>"
# Where contact-form submissions land and where customers should reply to.
RESEND_REPLY_TO="info@wgelecshop.com"

# ============================================================
# Pay By Link API Configuration
# ============================================================
PAYBYLINK_BASE_URL="https://eu-prod.oppwa.com"
PAYBYLINK_ENTITY_ID="your-entity-id"
PAYBYLINK_AUTH_TOKEN="your-bearer-token"
